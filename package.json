{
  "name": "fqdb",
  "version": "0.1.0",
  "description": "Persistent, indexed file queue for the browser. IndexedDB storage, Web Locks single-writer election, O(1) stats, scales to 10M+ items.",
  "keywords": [
    "queue",
    "indexeddb",
    "idb",
    "file-queue",
    "browser",
    "persistent",
    "web-locks",
    "download-queue",
    "upload-queue"
  ],
  "author": "Stefan Gordon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stefangordon/fqdb.git"
  },
  "homepage": "https://stefangordon.github.io/fqdb/",
  "bugs": {
    "url": "https://github.com/stefangordon/fqdb/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "demo:preview": "vite preview --config demo/vite.config.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.0",
    "fake-indexeddb": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
